      <uiProperties/>
      <varTables sizeState="INTERMEDIATE" name="Var" minimized="true"/>
      <outputTables sizeState="INTERMEDIATE" name="DIM_Discipline_out">
        <mapperTableEntries name="id_sport_sk" expression="Numeric.sequence(&quot;s1&quot;, 1, 1)" type="id_Integer"/>
        <mapperTableEntries name="discipline" expression="row1.discipline " type="id_String" nullable="true"/>
        <mapperTableEntries name="event" expression="row2.event " type="id_String" nullable="true"/>
        <mapperTableEntries name="gender" expression="row2.gender " type="id_Character" nullable="true"/>
        <mapperTableEntries name="hierarchie_sport" expression="row1.discipline == null ? &quot;Autre&quot; : &#xA;(row1.discipline.toLowerCase().contains(&quot;weightlifting&quot;) || row1.discipline.toLowerCase().contains(&quot;boxing&quot;) || row1.discipline.toLowerCase().contains(&quot;judo&quot;) || row1.discipline.toLowerCase().contains(&quot;karate&quot;) || row1.discipline.toLowerCase().contains(&quot;taekwondo&quot;) || row1.discipline.toLowerCase().contains(&quot;wrestling&quot;)) ? &quot;Power Sports&quot; :&#xA;(row1.discipline.toLowerCase().contains(&quot;cycling&quot;) || row1.discipline.toLowerCase().contains(&quot;rowing&quot;) || row1.discipline.toLowerCase().contains(&quot;triathlon&quot;)) ? &quot;Endurance Sports&quot; :&#xA;(row1.discipline.toLowerCase().contains(&quot;athletics&quot;) || row1.discipline.toLowerCase().contains(&quot;swimming&quot;) || row1.discipline.toLowerCase().contains(&quot;basketball&quot;) || row1.discipline.toLowerCase().contains(&quot;handball&quot;) || row1.discipline.toLowerCase().contains(&quot;hockey&quot;) || row1.discipline.toLowerCase().contains(&quot;football&quot;) || row1.discipline.toLowerCase().contains(&quot;rugby&quot;)) ? &quot;Speed Sports&quot; :&#xA;(row1.discipline.toLowerCase().contains(&quot;gymnastics&quot;) || row1.discipline.toLowerCase().contains(&quot;fencing&quot;) || row1.discipline.toLowerCase().contains(&quot;golf&quot;) || row1.discipline.toLowerCase().contains(&quot;shooting&quot;) || row1.discipline.toLowerCase().contains(&quot;archery&quot;) || row1.discipline.toLowerCase().contains(&quot;table tennis&quot;) || row1.discipline.toLowerCase().contains(&quot;badminton&quot;) || row1.discipline.toLowerCase().contains(&quot;tennis&quot;) || row1.discipline.toLowerCase().contains(&quot;baseball&quot;) || row1.discipline.toLowerCase().contains(&quot;softball&quot;)) ? &quot;Skill Sports&quot; :&#xA;(row1.discipline.toLowerCase().contains(&quot;aquatics&quot;) || row1.discipline.toLowerCase().contains(&quot;canoeing&quot;) || row1.discipline.toLowerCase().contains(&quot;sailing&quot;) || row1.discipline.toLowerCase().contains(&quot;surfing&quot;)) ? &quot;Water Sports&quot; :&#xA;(row1.discipline.toLowerCase().contains(&quot;skateboarding&quot;)) ? &quot;Board Sports&quot; :&#xA;(row1.discipline.toLowerCase().contains(&quot;modern pentathlon&quot;)) ? &quot;Combination Sports&quot; :&#xA;(row1.discipline.toLowerCase().contains(&quot;volleyball&quot;)) ? &quot;Team Sports&quot; : &quot;Autre&quot; " type="id_String" nullable="true"/>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="row1" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE">
        <mapperTableEntries name="id_discipline" type="id_Integer"/>
        <mapperTableEntries name="discipline_code" type="id_String" nullable="true"/>
        <mapperTableEntries name="discipline" type="id_String" nullable="true"/>
      </inputTables>
      <inputTables sizeState="INTERMEDIATE" name="row2" activateCondensedTool="true" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE" innerJoin="true">
